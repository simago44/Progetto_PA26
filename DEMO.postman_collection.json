              "key": "token",
              "value": "{{JWT_TOKEN_CREATOR}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"type\": \"english\",\r\n    \"startsAt\": \"{{futureDate1}}\",\r\n    \"endsAt\": \"{{futureDate2}}\",\r\n    \"reservePrice\": 500,\r\n    \"minimumIncrement\": 50,\r\n    \"delayBeforeEnding\": 0,\r\n    \"description\": \"dieci caratteri\"\r\n}",

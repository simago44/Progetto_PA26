    {
      "name": "Create English Auction",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const futureDate1 = new Date(Date.now() + 5 * 1000); // 30 seconds from now\r",
              "pm.collectionVariables.set('futureDate1', futureDate1);\r",
              "const futureDate2 = new Date(Date.now() + 5 * 60 * 1000); // 5 minutes from now\r",
              "pm.collectionVariables.set('futureDate2', futureDate2);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.collectionVariables.set(\"auctionId\", pm.response.json().id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [

      "name": "Create English Auction",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const futureDate1 = new Date(Date.now() + 10 * 60 * 1000);\r",
              "pm.environment.set('futureDate1', futureDate1);\r",
              "const futureDate2 = new Date(Date.now() + 20 * 60 * 1000);\r",
              "pm.environment.set('futureDate2', futureDate2);"
            ],

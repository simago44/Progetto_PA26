              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.collectionVariables.set(",
              "    \"USERNAME\",",
              "    pm.variables.replaceIn(\"{{$randomUserName}}\")",
              ");",
              "",
              "pm.collectionVariables.set(",
              "    \"PASSWORD\",",
              "    pm.variables.replaceIn(\"{{$randomPassword}}\") + \"aA@\"",
              ");"
            ],
